{
  "name": "sportsball",
  "version": "0.1.0",
  "description": "Sportsball — the FIFA World Cup 2026 in your terminal: schedule, favorites, live scores, ambient fav-alerts, browser streaming, highlights, stats, and AI analysis.",
  "type": "module",
  "bin": {
    "sportsball": "src/index.ts"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/sportsball",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MicroMediaSites/sportsball.git"
  },
  "bugs": {
    "url": "https://github.com/MicroMediaSites/sportsball/issues"
  },
  "homepage": "https://github.com/MicroMediaSites/sportsball#readme",
  "keywords": [
    "fifa",
    "world-cup",
    "wc2026",
    "soccer",
    "football",
    "cli",
    "terminal",
    "bun",
    "live-scores",
    "sports"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
